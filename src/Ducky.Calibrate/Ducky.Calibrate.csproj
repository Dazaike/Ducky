<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Ducky.Calibrate</AssemblyName>
    <Product>Ducky Calibrate</Product>
    <AssemblyTitle>Ducky Calibrate</AssemblyTitle>
    <ApplicationIcon>..\..\assets\ducky.ico</ApplicationIcon>
    <PublishAot>true</PublishAot>
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>partial</TrimMode>
    <InvariantGlobalization>true</InvariantGlobalization>
    <EnableComHosting>false</EnableComHosting>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <_SuppressWinFormsTrimError>true</_SuppressWinFormsTrimError>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Ducky.Core\Ducky.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\assets\ducky.ico" Link="ducky.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootDescriptor Include="rd.xml" />
  </ItemGroup>

</Project>
